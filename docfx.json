{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/EncDotNet.S100.Core/EncDotNet.S100.Core.csproj",
            "src/EncDotNet.S100.Datasets.S101/EncDotNet.S100.Datasets.S101.csproj",
            "src/EncDotNet.S100.Datasets.S102/EncDotNet.S100.Datasets.S102.csproj",
            "src/EncDotNet.S100.Datasets.S111/EncDotNet.S100.Datasets.S111.csproj",
            "src/EncDotNet.S100.ExchangeSets/EncDotNet.S100.ExchangeSets.csproj",
            "src/EncDotNet.S100.Features/EncDotNet.S100.Features.csproj",
            "src/EncDotNet.S100.Hdf5.PureHdf/EncDotNet.S100.Hdf5.PureHdf.csproj",
            "src/EncDotNet.S100.Portrayals/EncDotNet.S100.Portrayals.csproj",
            "src/EncDotNet.S100.Renderers.Mapsui/EncDotNet.S100.Renderers.Mapsui.csproj",
            "src/EncDotNet.S100.Renderers.Skia/EncDotNet.S100.Renderers.Skia.csproj",
            "src/EncDotNet.S100.Scripting.MoonSharp/EncDotNet.S100.Scripting.MoonSharp.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/**.md",
          "docs/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appLogoPath": "docs/images/logo.svg",
      "_appFaviconPath": "docs/images/logo.svg"
    }
  }
}
