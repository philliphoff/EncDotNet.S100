<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
             xmlns:loc="using:EncDotNet.S100.Viewer.Resources"
             x:Class="EncDotNet.S100.Viewer.Views.FeatureSearchView"
             x:DataType="vm:FeatureSearchViewModel">

    <DockPanel LastChildFill="True">

        <!-- Query box -->
        <Border DockPanel.Dock="Top" Padding="12,8,12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         x:Name="SearchBox"
                         Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="{x:Static loc:Strings.Search_Placeholder}"
                         VerticalContentAlignment="Center"
                         Padding="8,4" />
                <Button Grid.Column="1"
                        Margin="4,0,0,0"
                        Padding="8,4"
                        Command="{Binding ClearQueryCommand}"
                        IsVisible="{Binding Query, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        ToolTip.Tip="{x:Static loc:Strings.Tooltip_ClearSearch}">
                    <ic:FluentIcon Icon="Dismiss" IconVariant="Regular" FontSize="14" />
                </Button>
            </Grid>
        </Border>

        <!-- Footer: result count / truncation / no-results -->
        <Border DockPanel.Dock="Bottom"
                Padding="12,4,12,8"
                IsVisible="{Binding Summary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding Summary}"
                       FontSize="11"
                       Opacity="0.7"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Results list -->
        <ListBox ItemsSource="{Binding Results}"
                 SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                 SelectionMode="Single"
                 BorderThickness="0"
                 Background="Transparent"
                 Padding="0">
            <ListBox.Styles>
                <!--
                    ShadUI's ListBoxItem template (Controls/ListBox/
                    ListBoxItem.axaml) layers three template borders —
                    BaseBackground, HoverBackground, SelectionBackground —
                    plus a PathIcon#CheckSelected that is shown on
                    :selected. Override SelectionBackground to paint the
                    configured accent across the whole row, and hide the
                    check icon entirely so selected rows read as a solid
                    coloured strip.
                -->
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="12,6" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ Border#SelectionBackground">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ PathIcon#CheckSelected">
                    <Setter Property="IsVisible" Value="False" />
                </Style>
                <Style Selector="ListBoxItem:selected TextBlock">
                    <Setter Property="Foreground" Value="White" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:FeatureSearchResultItem">
                    <StackPanel Orientation="Vertical"
                                Spacing="2"
                                ToolTip.Tip="{x:Static loc:Strings.Tooltip_OpenSearchResult}">
                        <TextBlock Text="{Binding DisplayType}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding FeatureRef}"
                                   FontSize="11"
                                   Opacity="0.75" />
                        <TextBlock FontSize="10"
                                   Opacity="0.55"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding ProductSpec}" />
                            <Run Text="·" />
                            <Run Text="{Binding DatasetFileName}" />
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>

</UserControl>
