<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:EncDotNet.S100.Viewer.Services"
        x:Class="EncDotNet.S100.Viewer.Views.DatasetLoadFailureDialog"
        x:DataType="svc:LoadFailureViewModel"
        Title="{Binding Title}"
        Width="520"
        SizeToContent="Height"
        MinHeight="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

        <!-- Heading: warning icon + display name -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <PathIcon Width="20"
                      Height="20"
                      VerticalAlignment="Center"
                      Foreground="#E0A33B"
                      Data="M12 2 L22 21 L2 21 Z M12 9 L12 14 M12 17 L12 18.5" />
            <TextBlock Text="{Binding DisplayName}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Primary message -->
        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Text="{Binding PrimaryMessage}"
                   TextWrapping="Wrap" />

        <!-- File path -->
        <StackPanel Grid.Row="2"
                    Margin="0,10,0,0"
                    Orientation="Horizontal"
                    Spacing="6">
            <TextBlock Text="{Binding FilePathLabel}"
                       FontWeight="SemiBold"
                       Opacity="0.7" />
            <TextBlock Text="{Binding FilePath}"
                       FontFamily="Consolas, Menlo, Monaco, monospace"
                       TextWrapping="Wrap"
                       Opacity="0.85" />
        </StackPanel>

        <!-- Spec reference (only when present) -->
        <TextBlock Grid.Row="3"
                   Margin="0,6,0,0"
                   Text="{Binding SpecReference}"
                   FontStyle="Italic"
                   FontSize="11"
                   Opacity="0.7"
                   IsVisible="{Binding HasSpecReference}" />

        <!-- Details expander -->
        <Expander Grid.Row="4"
                  Margin="0,14,0,0"
                  Header="{Binding ShowDetailsLabel}">
            <TextBox Text="{Binding Details, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas, Menlo, Monaco, monospace"
                     FontSize="11"
                     Height="200"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Expander>

        <!-- Buttons row -->
        <Grid Grid.Row="5"
              Margin="0,16,0,0"
              ColumnDefinitions="*,Auto,Auto,Auto">
            <TextBlock Name="CopyConfirmation"
                       Grid.Column="0"
                       Text="{Binding DetailsCopiedLabel}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Opacity="0">
                <TextBlock.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                    </Transitions>
                </TextBlock.Transitions>
            </TextBlock>

            <Button Grid.Column="1"
                    Name="CopyDetailsButton"
                    Content="{Binding CopyDetailsLabel}"
                    ToolTip.Tip="{Binding CopyDetailsTooltip}"
                    Click="OnCopyDetailsClick" />

            <Button Grid.Column="2"
                    Margin="8,0,0,0"
                    Name="CloseButton"
                    Content="{Binding CloseLabel}"
                    ToolTip.Tip="{Binding CloseTooltip}"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </Grid>
    </Grid>
</Window>
