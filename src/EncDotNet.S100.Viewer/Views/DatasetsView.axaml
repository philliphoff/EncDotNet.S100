<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
             x:Class="EncDotNet.S100.Viewer.Views.DatasetsView"
             x:DataType="vm:DatasetsViewModel">

    <DockPanel>
        <Button DockPanel.Dock="Bottom"
                Classes="Outline"
                Content="Open Dataset..."
                HorizontalAlignment="Stretch"
                Margin="8"
                x:Name="AddButton" />

        <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Entries}"
                      Margin="8,4"
                      x:Name="DatasetList"
                      DoubleTapped="OnDatasetDoubleTapped">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="8" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DatasetEntry">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ProductSpec}"
                                       FontSize="11"
                                       Opacity="0.6" />
                            <TextBlock Text="{Binding Info}"
                                       FontSize="11"
                                       Opacity="0.5"
                                       IsVisible="{Binding IsLoaded}"
                                       TextWrapping="Wrap" />
                            <!-- Time step controls (S-111) -->
                            <StackPanel Orientation="Horizontal"
                                        IsVisible="{Binding HasTimeSteps}"
                                        Margin="0,4,0,0"
                                        Spacing="4">
                                <Button Classes="Icon" Padding="2"
                                        Command="{Binding PreviousTimeStepCommand}">
                                    <ic:FluentIcon Icon="ChevronLeft" IconVariant="Regular" FontSize="12" />
                                </Button>
                                <ComboBox ItemsSource="{Binding TimeStepLabels}"
                                          SelectedIndex="{Binding SelectedTimeIndex}"
                                          FontSize="11"
                                          Padding="4,2"
                                          MinHeight="0"
                                          VerticalAlignment="Center" />
                                <Button Classes="Icon" Padding="2"
                                        Command="{Binding NextTimeStepCommand}">
                                    <ic:FluentIcon Icon="ChevronRight" IconVariant="Regular" FontSize="12" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="Icon"
                                Command="{Binding $parent[ItemsControl].((vm:DatasetsViewModel)DataContext).RemoveCommand}"
                                CommandParameter="{Binding}"
                                VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Delete" IconVariant="Regular" FontSize="16" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
