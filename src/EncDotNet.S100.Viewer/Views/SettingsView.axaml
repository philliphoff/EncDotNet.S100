<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
             x:Class="EncDotNet.S100.Viewer.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel Margin="12" Spacing="12">
        <TextBlock Text="Application Settings"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Opacity="0.7" />
        <TextBlock Text="No configurable settings yet."
                   Opacity="0.5" />
    </StackPanel>
</UserControl>
