<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
             xmlns:viewer="using:EncDotNet.S100.Viewer"
             xmlns:loc="using:EncDotNet.S100.Viewer.Resources"
             x:Class="EncDotNet.S100.Viewer.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                   VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" Spacing="16">
            <TextBlock Text="{x:Static loc:Strings.Settings_Heading}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Opacity="0.7" />

            <!-- Accent Color -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Static loc:Strings.Settings_AccentColor}"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <ColorPicker Color="{Binding AccentColor}"
                             IsAlphaVisible="False"
                             HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Color Profile -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Static loc:Strings.Settings_ColorProfile}"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock Text="{x:Static loc:Strings.Settings_ColorProfile_Help}"
                           FontSize="11"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
                <ComboBox ItemsSource="{Binding AvailablePalettes}"
                          SelectedItem="{Binding SelectedPalette}"
                          MinWidth="140"
                          HorizontalAlignment="Left">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={x:Static viewer:PaletteTypeNameConverter.Instance}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Symbol Scale -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Static loc:Strings.Settings_SymbolScale}"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock Text="{x:Static loc:Strings.Settings_SymbolScale_Help}"
                           FontSize="11"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,Auto">
                    <Slider Grid.Column="0"
                            Minimum="0.5"
                            Maximum="3.0"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding SymbolScale}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SymbolScale, StringFormat={}{0:F1}x}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               MinWidth="36" />
                </Grid>
            </StackPanel>

            <!-- Text Scale -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Static loc:Strings.Settings_TextScale}"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock Text="{x:Static loc:Strings.Settings_TextScale_Help}"
                           FontSize="11"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,Auto">
                    <Slider Grid.Column="0"
                            Minimum="0.5"
                            Maximum="3.0"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding TextScale}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding TextScale, StringFormat={}{0:F1}x}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               MinWidth="36" />
                </Grid>
            </StackPanel>

            <!-- Distance Unit -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Static loc:Strings.Settings_DistanceUnits}"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock Text="{x:Static loc:Strings.Settings_DistanceUnits_Help}"
                           FontSize="11"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
                <ComboBox ItemsSource="{Binding AvailableDistanceUnits}"
                          SelectedItem="{Binding DistanceUnit}"
                          MinWidth="180"
                          HorizontalAlignment="Left">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="viewer:DistanceUnit">
                            <TextBlock Text="{Binding Converter={x:Static viewer:DistanceUnitNameConverter.Instance}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
