<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
             x:Class="EncDotNet.S100.Viewer.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                   VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" Spacing="16">
            <TextBlock Text="Application Settings"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Opacity="0.7" />

            <!-- Accent Color -->
            <StackPanel Spacing="6">
                <TextBlock Text="Accent Color"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <ColorView Color="{Binding AccentColor}"
                           IsAlphaVisible="False"
                           IsColorComponentsVisible="False"
                           IsColorSpectrumSliderVisible="True"
                           MaxWidth="300"
                           HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Color Profile -->
            <StackPanel Spacing="6">
                <TextBlock Text="Color Profile"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock Text="Controls the Day/Dusk/Night color palette used across all datasets."
                           FontSize="11"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
                <ComboBox ItemsSource="{Binding AvailablePalettes}"
                          SelectedItem="{Binding SelectedPalette}"
                          MinWidth="140"
                          HorizontalAlignment="Left" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
