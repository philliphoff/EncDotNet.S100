<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
             xmlns:loc="using:EncDotNet.S100.Viewer.Resources"
             x:Class="EncDotNet.S100.Viewer.Views.TimelineView"
             x:DataType="vm:TimelineViewModel">

    <Border Background="{DynamicResource BackgroundColor}"
            Padding="12,8">
        <DockPanel LastChildFill="True">

            <!-- Title row -->
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="Auto,*,Auto"
                  Margin="0,0,0,4">
                <TextBlock Grid.Column="0"
                           Text="{x:Static loc:Strings.TimelinePanel_Title}"
                           FontSize="11"
                           FontWeight="Normal"
                           LetterSpacing="1" />
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentTimeLabel}"
                           FontSize="12"
                           FontFamily="Menlo, Consolas, monospace" />
            </Grid>

            <!-- Range summary -->
            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding RangeLabel}"
                       FontSize="11"
                       Opacity="0.6"
                       Margin="0,4,0,0" />

            <!-- Slider -->
            <Slider Minimum="{Binding SliderMinimum, Mode=OneWay}"
                    Maximum="{Binding SliderMaximum, Mode=OneWay}"
                    Value="{Binding SliderValue, Mode=TwoWay}"
                    IsSnapToTickEnabled="False"
                    TickPlacement="BottomRight"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{x:Static loc:Strings.Tooltip_TimelineSlider}" />
        </DockPanel>
    </Border>
</UserControl>
