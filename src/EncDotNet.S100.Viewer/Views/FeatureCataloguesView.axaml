<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
             x:Class="EncDotNet.S100.Viewer.Views.FeatureCataloguesView"
             x:DataType="vm:FeatureCataloguesViewModel">

    <DockPanel>
        <Button DockPanel.Dock="Bottom"
                Classes="Outline"
                Content="Add Feature Catalogue..."
                HorizontalAlignment="Stretch"
                Margin="8"
                x:Name="AddButton" />

        <ListBox ItemsSource="{Binding Entries}"
                 Margin="0,4">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:CatalogueEntry">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProductSpec}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Path}"
                                       FontSize="11"
                                       Opacity="0.6"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="Ghost"
                                Content="✕"
                                Command="{Binding $parent[ListBox].((vm:FeatureCataloguesViewModel)DataContext).RemoveCommand}"
                                CommandParameter="{Binding}"
                                VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
