<shadui:Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
        xmlns:views="using:EncDotNet.S100.Viewer.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="EncDotNet.S100.Viewer.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="S-100 Viewer"
        Width="1100" Height="700"
        IsTitleBarVisible="True"
        ShowBottomBorder="True">

    <shadui:Window.RightWindowTitleBarContent>
        <Button Command="{Binding ToggleThemeCommand}"
                ToolTip.Tip="Toggle Light/Dark Theme"
                Width="32" Height="28"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0">
            <Panel>
                <!-- Sun icon (shown in dark mode, click to go light) -->
                <ic:FluentIcon Icon="WeatherSunny" IconVariant="Regular" FontSize="16"
                               Foreground="{DynamicResource ForegroundColor}"
                               IsVisible="{Binding IsDarkTheme}" />
                <!-- Moon icon (shown in light mode, click to go dark) -->
                <ic:FluentIcon Icon="WeatherMoon" IconVariant="Regular" FontSize="16"
                               Foreground="{DynamicResource ForegroundColor}"
                               IsVisible="{Binding !IsDarkTheme}" />
            </Panel>
        </Button>
    </shadui:Window.RightWindowTitleBarContent>

    <DockPanel>
        <!-- Status bar at bottom -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BackgroundColor}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="8,3"
                IsVisible="{Binding IsStatusVisible}">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Opacity="0.7" />
        </Border>

        <!-- Activity bar (narrow icon strip on far left) -->
        <Border DockPanel.Dock="Left"
                Background="{DynamicResource BackgroundColor}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,1,0"
                Width="52"
                Padding="4,0">
            <DockPanel>
                <!-- Settings pinned at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Spacing="2" Margin="0,4">
                    <ToggleButton IsChecked="{Binding IsSettingsSelected, Mode=OneWay}"
                                  Command="{Binding SelectSettingsCommand}"
                                  ToolTip.Tip="Settings"
                                  Width="44" Height="44"
                                  Padding="0"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Background="Transparent"
                                  BorderThickness="0">
                        <ic:FluentIcon Icon="Settings" IconVariant="Regular" FontSize="22"
                                        Foreground="{DynamicResource ForegroundColor}" />
                    </ToggleButton>
                </StackPanel>

                <!-- Top group: main activities -->
                <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,4">
                    <!-- Feature Catalogues -->
                    <ToggleButton IsChecked="{Binding IsFeatureCataloguesSelected, Mode=OneWay}"
                                  Command="{Binding SelectFeatureCataloguesCommand}"
                                  ToolTip.Tip="Feature Catalogues"
                                  Width="44" Height="44"
                                  Padding="0"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Background="Transparent"
                                  BorderThickness="0">
                        <ic:FluentIcon Icon="BookOpen" IconVariant="Regular" FontSize="22"
                                        Foreground="{DynamicResource ForegroundColor}" />
                    </ToggleButton>

                    <!-- Portrayal Catalogues -->
                    <ToggleButton IsChecked="{Binding IsPortrayalCataloguesSelected, Mode=OneWay}"
                                  Command="{Binding SelectPortrayalCataloguesCommand}"
                                  ToolTip.Tip="Portrayal Catalogues"
                                  Width="44" Height="44"
                                  Padding="0"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Background="Transparent"
                                  BorderThickness="0">
                        <ic:FluentIcon Icon="PaintBrush" IconVariant="Regular" FontSize="22"
                                        Foreground="{DynamicResource ForegroundColor}" />
                    </ToggleButton>

                    <!-- Datasets -->
                    <ToggleButton IsChecked="{Binding IsDatasetsSelected, Mode=OneWay}"
                                  Command="{Binding SelectDatasetsCommand}"
                                  ToolTip.Tip="Datasets"
                                  Width="44" Height="44"
                                  Padding="0"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Background="Transparent"
                                  BorderThickness="0">
                        <ic:FluentIcon Icon="Layer" IconVariant="Regular" FontSize="22"
                                        Foreground="{DynamicResource ForegroundColor}" />
                    </ToggleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Activity pane + splitter + map in a resizable grid -->
        <Grid x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200" MaxWidth="600" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Activity pane -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BackgroundColor}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,1,0"
                    IsVisible="{Binding IsPaneVisible}">
                <DockPanel>
                    <!-- Pane header -->
                    <Border DockPanel.Dock="Top"
                            Padding="12,8"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding PaneTitle}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </Border>

                    <!-- Pane content: show the appropriate view based on selection -->
                    <Panel>
                        <views:FeatureCataloguesView DataContext="{Binding FeatureCatalogues}"
                                                     IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsFeatureCataloguesSelected}" />
                        <views:PortrayalCataloguesView DataContext="{Binding PortrayalCatalogues}"
                                                       IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsPortrayalCataloguesSelected}" />
                        <views:DatasetsView DataContext="{Binding Datasets}"
                                            IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsDatasetsSelected}" />
                        <views:SettingsView DataContext="{Binding Settings}"
                                            IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsSettingsSelected}" />
                    </Panel>
                </DockPanel>
            </Border>

            <!-- Resize grip between pane and map -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          IsVisible="{Binding IsPaneVisible}" />

            <!-- Map control fills remaining space -->
            <mapsui:MapControl Grid.Column="2" x:Name="MapControl" />
        </Grid>
    </DockPanel>
</shadui:Window>
