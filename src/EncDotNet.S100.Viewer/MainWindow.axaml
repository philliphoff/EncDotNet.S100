<shadui:Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        xmlns:vm="using:EncDotNet.S100.Viewer.ViewModels"
        xmlns:pp="using:EncDotNet.S100.Datasets.Pipelines"
        xmlns:views="using:EncDotNet.S100.Viewer.Views"
        xmlns:loc="using:EncDotNet.S100.Viewer.Resources"
        xmlns:bh="using:EncDotNet.S100.Viewer.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="EncDotNet.S100.Viewer.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{x:Static loc:Strings.Window_Title}"
        Width="1100" Height="700"
        IsTitleBarVisible="True"
        ShowBottomBorder="True">

    <shadui:Window.LogoContent>
        <ic:FluentIcon Icon="Map" IconVariant="Regular" FontSize="14"
                       Margin="8,0,0,0" />
    </shadui:Window.LogoContent>

    <shadui:Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />
    </shadui:Window.Resources>

    <shadui:Window.KeyBindings>
        <!-- Esc exits the active map tool (pick or measure). -->
        <KeyBinding Gesture="Escape" Command="{Binding ExitPickModeCommand}" />
        <!-- Cmd+M / Ctrl+M toggles Measure Mode. -->
        <KeyBinding Gesture="Cmd+M" Command="{Binding ToggleMeasureModeCommand}" />
        <KeyBinding Gesture="Ctrl+M" Command="{Binding ToggleMeasureModeCommand}" />
        <!-- Enter / Backspace are tool actions while a tool is active. -->
        <KeyBinding Gesture="Enter" Command="{Binding ToolCommitCommand}" />
        <KeyBinding Gesture="Back" Command="{Binding ToolBackstepCommand}" />
    </shadui:Window.KeyBindings>

    <shadui:Window.Styles>
        <!-- Activity bar toggle buttons: no fill, muted icon, primary on hover/selected -->
        <Style Selector="ToggleButton.ActivityIcon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MutedColor}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Padding="{TemplateBinding Padding}"
                                      Background="Transparent" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.ActivityIcon:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>
        <Style Selector="ToggleButton.ActivityIcon:checked">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>
        <!-- Inherit foreground into the FluentIcon inside -->
        <Style Selector="ToggleButton.ActivityIcon ic|FluentIcon">
            <Setter Property="Foreground" Value="{Binding $parent[ToggleButton].Foreground}" />
        </Style>

        <!--
          Shared GridSplitter look-and-feel. Apply via Classes="PaneSplitter"
          to every splitter in the viewer (main pane, pick panel, catalog
          details). The splitter itself stays transparent at rest so it
          blends with its surroundings; the accent color appears only on
          hover or while the user is actively dragging.
        -->
        <!--
          The splitter is transparent at rest. The shared `HoverDelay`
          attached behavior (set on each splitter individually) waits
          500ms after pointer-enter before adding the `hovered` class,
          so a quick pass-through never reveals the accent. Exit is
          immediate. While dragging, `:pressed` keeps the accent
          regardless of pointer position.
        -->
        <Style Selector="GridSplitter.PaneSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="GridSplitter.PaneSplitter.hovered">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="GridSplitter.PaneSplitter:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!--
          Map overlay buttons (Pick Mode, Zoom In/Out/Extent) sit on top
          of the map. The default ShadUI Icon foreground uses MutedColor
          which is hard to read against the chart canvas — bump these
          buttons to the full ForegroundColor at rest so the icons are
          legible. (Background is left at the ShadUI default to avoid
          the hover-overlay shimmer that occurs when the resting fill
          and the GhostColor hover overlay differ.)
        -->
        <Style Selector="Button.MapOverlay">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
        <Style Selector="Button.MapOverlay ic|FluentIcon">
            <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
        </Style>

    </shadui:Window.Styles>

    <shadui:Window.RightWindowTitleBarContent>
        <Button Command="{Binding ToggleThemeCommand}"
                ToolTip.Tip="{x:Static loc:Strings.Tooltip_ToggleTheme}"
                Width="32" Height="28"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0">
            <Panel>
                <!-- Sun icon (shown in dark mode, click to go light) -->
                <ic:FluentIcon Icon="WeatherSunny" IconVariant="Regular" FontSize="16"
                               Foreground="{DynamicResource ForegroundColor}"
                               IsVisible="{Binding IsDarkTheme}" />
                <!-- Moon icon (shown in light mode, click to go dark) -->
                <ic:FluentIcon Icon="WeatherMoon" IconVariant="Regular" FontSize="16"
                               Foreground="{DynamicResource ForegroundColor}"
                               IsVisible="{Binding !IsDarkTheme}" />
            </Panel>
        </Button>
    </shadui:Window.RightWindowTitleBarContent>

    <DockPanel>
        <!-- Status bar at bottom -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BackgroundColor}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="8,3"
                Height="26"
                IsVisible="{Binding IsStatusBarVisible}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding MouseLatLonText}"
                           FontSize="12"
                           FontFamily="Menlo,Consolas,Courier New,monospace"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           ToolTip.Tip="{x:Static loc:Strings.Tooltip_MouseLatLon}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding MeasureSummary}"
                           IsVisible="{Binding IsMeasureModeActive}"
                           FontSize="12"
                           FontFamily="Menlo,Consolas,Courier New,monospace"
                           Opacity="0.85"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!-- Activity bar (narrow icon strip on far left) -->
        <Border DockPanel.Dock="Left"
                Background="{DynamicResource BackgroundColor}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,1,0"
                Width="48"
                Padding="0">
            <DockPanel>
                <!-- Settings pinned at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Spacing="2" Margin="0,4">
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                IsVisible="{Binding IsSettingsSelected}" />
                        <ToggleButton Classes="ActivityIcon"
                                      IsChecked="{Binding IsSettingsSelected, Mode=OneWay}"
                                      Command="{Binding SelectSettingsCommand}"
                                      ToolTip.Tip="{x:Static loc:Strings.Tooltip_Settings}"
                                      Height="48"
                                      Padding="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                            <ic:FluentIcon Icon="Settings" IconVariant="Regular" FontSize="22" />
                        </ToggleButton>
                    </Grid>
                </StackPanel>

                <!-- Top group: main activities -->
                <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,4">
                    <!-- Feature Catalogues -->
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                IsVisible="{Binding IsFeatureCataloguesSelected}" />
                        <ToggleButton Classes="ActivityIcon"
                                      IsChecked="{Binding IsFeatureCataloguesSelected, Mode=OneWay}"
                                      Command="{Binding SelectFeatureCataloguesCommand}"
                                      ToolTip.Tip="{x:Static loc:Strings.Tooltip_FeatureCatalogues}"
                                      Height="48"
                                      Padding="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                            <ic:FluentIcon Icon="BookOpen" IconVariant="Regular" FontSize="22" />
                        </ToggleButton>
                    </Grid>

                    <!-- Portrayal Catalogues -->
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                IsVisible="{Binding IsPortrayalCataloguesSelected}" />
                        <ToggleButton Classes="ActivityIcon"
                                      IsChecked="{Binding IsPortrayalCataloguesSelected, Mode=OneWay}"
                                      Command="{Binding SelectPortrayalCataloguesCommand}"
                                      ToolTip.Tip="{x:Static loc:Strings.Tooltip_PortrayalCatalogues}"
                                      Height="48"
                                      Padding="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                            <ic:FluentIcon Icon="PaintBrush" IconVariant="Regular" FontSize="22" />
                        </ToggleButton>
                    </Grid>

                    <!-- Datasets -->
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                IsVisible="{Binding IsDatasetsSelected}" />
                        <ToggleButton Classes="ActivityIcon"
                                      IsChecked="{Binding IsDatasetsSelected, Mode=OneWay}"
                                      Command="{Binding SelectDatasetsCommand}"
                                      ToolTip.Tip="{x:Static loc:Strings.Tooltip_Datasets}"
                                      Height="48"
                                      Padding="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                            <ic:FluentIcon Icon="Layer" IconVariant="Regular" FontSize="22" />
                        </ToggleButton>
                    </Grid>

                    <!-- Dataset Catalog -->
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                IsVisible="{Binding IsCatalogSelected}" />
                        <ToggleButton Classes="ActivityIcon"
                                      IsChecked="{Binding IsCatalogSelected, Mode=OneWay}"
                                      Command="{Binding SelectCatalogCommand}"
                                      ToolTip.Tip="{x:Static loc:Strings.Tooltip_Catalog}"
                                      Height="48"
                                      Padding="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                            <ic:FluentIcon Icon="Library" IconVariant="Regular" FontSize="22" />
                        </ToggleButton>
                    </Grid>

                    <!-- Search -->
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                IsVisible="{Binding IsSearchSelected}" />
                        <ToggleButton Classes="ActivityIcon"
                                      IsChecked="{Binding IsSearchSelected, Mode=OneWay}"
                                      Command="{Binding SelectSearchCommand}"
                                      ToolTip.Tip="{x:Static loc:Strings.Tooltip_Search}"
                                      Height="48"
                                      Padding="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                            <ic:FluentIcon Icon="Search" IconVariant="Regular" FontSize="22" />
                        </ToggleButton>
                    </Grid>

                    <!-- ECDIS Display Controls -->
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                IsVisible="{Binding IsEcdisDisplaySelected}" />
                        <ToggleButton Classes="ActivityIcon"
                                      IsChecked="{Binding IsEcdisDisplaySelected, Mode=OneWay}"
                                      Command="{Binding SelectEcdisDisplayCommand}"
                                      ToolTip.Tip="{x:Static loc:Strings.Tooltip_EcdisDisplay}"
                                      Height="48"
                                      Padding="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                            <ic:FluentIcon Icon="Eye" IconVariant="Regular" FontSize="22" />
                        </ToggleButton>
                    </Grid>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Activity pane + splitter + map + pick panel in a resizable grid -->
        <Grid x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200" MaxWidth="600"
                                  bh:CollapsibleColumn.IsVisible="{Binding IsPaneVisible}"
                                  bh:CollapsibleColumn.ExpandedWidth="320"
                                  bh:CollapsibleColumn.MinWidthWhenVisible="200"
                                  bh:CollapsibleColumn.MaxWidthWhenVisible="600" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="360" MinWidth="240" MaxWidth="600"
                                  bh:CollapsibleColumn.IsVisible="{Binding IsPickPanelVisible}"
                                  bh:CollapsibleColumn.ExpandedWidth="360"
                                  bh:CollapsibleColumn.MinWidthWhenVisible="240"
                                  bh:CollapsibleColumn.MaxWidthWhenVisible="600" />
            </Grid.ColumnDefinitions>

            <!-- Activity pane -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BackgroundColor}"
                    IsVisible="{Binding IsPaneVisible}">
                <DockPanel>
                    <!-- Pane header -->
                    <Border DockPanel.Dock="Top"
                            Padding="12,8">
                        <TextBlock Text="{Binding PaneTitle}"
                                   FontSize="11"
                                   FontWeight="Normal"
                                   LetterSpacing="1" />
                    </Border>

                    <!-- Pane content: show the appropriate view based on selection -->
                    <Panel>
                        <views:FeatureCataloguesView DataContext="{Binding FeatureCatalogues}"
                                                     IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsFeatureCataloguesSelected}" />
                        <views:PortrayalCataloguesView DataContext="{Binding PortrayalCatalogues}"
                                                       IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsPortrayalCataloguesSelected}" />
                        <views:DatasetsView DataContext="{Binding Datasets}"
                                            IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsDatasetsSelected}" />
                        <views:CatalogPanelView DataContext="{Binding CatalogPanel}"
                                                IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsCatalogSelected}" />
                        <views:FeatureSearchView DataContext="{Binding Search}"
                                                 IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsSearchSelected}" />
                        <views:SettingsView DataContext="{Binding Settings}"
                                            IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsSettingsSelected}" />
                        <views:EcdisDisplayPanelView DataContext="{Binding EcdisDisplayPanel}"
                                                     IsVisible="{Binding $parent[shadui:Window].((vm:MainViewModel)DataContext).IsEcdisDisplaySelected}" />
                    </Panel>
                </DockPanel>
            </Border>

            <!-- Resize grip between pane and map -->
            <GridSplitter Grid.Column="1"
                          Classes="PaneSplitter"
                          Width="4"
                          ResizeDirection="Columns"
                          IsVisible="{Binding IsPaneVisible}"
                          bh:HoverDelay.DelayMilliseconds="500"
                          Name="PaneSplitter" />

            <!-- Map control fills remaining space, with zoom buttons overlaid -->
            <!-- Map column wrapped in a row-grid so a timeline panel can dock at the bottom -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="100" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="120" MinHeight="100"
                                   bh:CollapsibleRow.IsVisible="{Binding IsTimelineVisible}"
                                   bh:CollapsibleRow.ExpandedHeight="120"
                                   bh:CollapsibleRow.MinHeightWhenVisible="100" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" DragDrop.AllowDrop="True">
                <mapsui:MapControl x:Name="MapControl" />
                <views:ScaleBarView x:Name="ScaleBar"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,4,0,0" />
                <StackPanel Orientation="Vertical"
                            Spacing="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,12,12,0">
                    <Button x:Name="PickModeButton"
                            Classes="Icon MapOverlay"
                            Classes.pickActive="{Binding IsPickModeActive}"
                            Command="{Binding TogglePickModeCommand}"
                            ToolTip.Tip="{x:Static loc:Strings.Tooltip_PickMode}">
                        <Button.Styles>
                            <!--
                              When pick mode is active we add the "pickActive"
                              class from code-behind; this fills the button with
                              the accent color so the user can tell at a glance.
                              Using Button (not ToggleButton) lets us keep the
                              exact resting appearance of the adjacent zoom
                              buttons — ShadUI's `Classes="Icon"` only styles
                              Button, not ToggleButton.
                            -->
                            <Style Selector="Button#PickModeButton.pickActive">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                            <Style Selector="Button#PickModeButton.pickActive /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Style>
                            <!--
                              Force the FluentIcon child to inherit the
                              button's Foreground so the toggled-on state
                              actually paints the icon white. (The default
                              FluentIcon Foreground is bound to the theme
                              text color and would otherwise stay dark.)
                            -->
                            <Style Selector="Button#PickModeButton.pickActive ic|FluentIcon">
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                            <!--
                              ShadUI's Button.Icon template stacks a separate
                              Border#HoverBackground on top of the base whose
                              Background is bound to ButtonAssist.HoverBackground
                              (default GhostColor). Override it so the active
                              fill stays accent-colored on hover.
                            -->
                            <Style Selector="Button#PickModeButton.pickActive /template/ Border#HoverBackground">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <!--
                                  Pin opacity to 1 so the 0→1 fade-in transition
                                  doesn't briefly blend with the base layer when
                                  the cursor enters the button.
                                -->
                                <Setter Property="Opacity" Value="1" />
                            </Style>
                        </Button.Styles>
                        <ic:FluentIcon Icon="CursorClick" IconVariant="Regular" FontSize="16" />
                    </Button>
                    <!--
                      Measure Mode toggle button. Same accent-fill pattern
                      as PickModeButton above; ruler icon distinguishes the
                      two. Cmd/Ctrl+M is the keyboard accelerator (see the
                      Window.KeyBindings block at the top of this file).
                    -->
                    <Button x:Name="MeasureModeButton"
                            Classes="Icon MapOverlay"
                            Classes.measureActive="{Binding IsMeasureModeActive}"
                            Command="{Binding ToggleMeasureModeCommand}"
                            ToolTip.Tip="{x:Static loc:Strings.Tooltip_MeasureMode}">
                        <Button.Styles>
                            <Style Selector="Button#MeasureModeButton.measureActive">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                            <Style Selector="Button#MeasureModeButton.measureActive /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Style>
                            <Style Selector="Button#MeasureModeButton.measureActive ic|FluentIcon">
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                            <Style Selector="Button#MeasureModeButton.measureActive /template/ Border#HoverBackground">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Opacity" Value="1" />
                            </Style>
                        </Button.Styles>
                        <ic:FluentIcon Icon="Ruler" IconVariant="Regular" FontSize="16" />
                    </Button>
                    <!--
                      Display category pill — compact label that opens
                      a flyout to switch between ECDIS display categories.
                    -->
                    <Button Classes="MapOverlay"
                            ToolTip.Tip="{x:Static loc:Strings.Tooltip_DisplayMode}"
                            Padding="8,4"
                            FontSize="11"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Content="{Binding DisplayToolbar.ActiveCategoryLabel}">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Spacing="4" MinWidth="160">
                                    <RadioButton Content="{x:Static loc:Strings.DisplayCategory_DisplayBase}"
                                                 IsChecked="{Binding DisplayToolbar.IsDisplayBase, Mode=OneWay}"
                                                 GroupName="DisplayCategoryFlyout">
                                        <RadioButton.Command>
                                            <Binding Path="DisplayToolbar.SetDisplayBaseCommand" />
                                        </RadioButton.Command>
                                    </RadioButton>
                                    <RadioButton Content="{x:Static loc:Strings.DisplayCategory_Standard}"
                                                 IsChecked="{Binding DisplayToolbar.IsStandard, Mode=OneWay}"
                                                 GroupName="DisplayCategoryFlyout">
                                        <RadioButton.Command>
                                            <Binding Path="DisplayToolbar.SetStandardCommand" />
                                        </RadioButton.Command>
                                    </RadioButton>
                                    <RadioButton Content="{x:Static loc:Strings.DisplayCategory_OtherInformation}"
                                                 IsChecked="{Binding DisplayToolbar.IsOtherInformation, Mode=OneWay}"
                                                 GroupName="DisplayCategoryFlyout">
                                        <RadioButton.Command>
                                            <Binding Path="DisplayToolbar.SetOtherInformationCommand" />
                                        </RadioButton.Command>
                                    </RadioButton>
                                    <RadioButton Content="{x:Static loc:Strings.DisplayCategory_All}"
                                                 IsChecked="{Binding DisplayToolbar.IsAll, Mode=OneWay}"
                                                 GroupName="DisplayCategoryFlyout">
                                        <RadioButton.Command>
                                            <Binding Path="DisplayToolbar.SetAllCommand" />
                                        </RadioButton.Command>
                                    </RadioButton>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!--
                      Zoom in / out / to-extent group. Wrapping in an inner
                      StackPanel with vertical margin gives the cluster its
                      own visual grouping (separated from the Pick Mode
                      button above and the compass rose below).
                    -->
                    <StackPanel Orientation="Vertical" Spacing="2" Margin="0,16,0,16">
                        <Button x:Name="ZoomInButton"
                                Classes="Icon MapOverlay"
                                ToolTip.Tip="{x:Static loc:Strings.Tooltip_ZoomIn}">
                            <ic:FluentIcon Icon="ZoomIn" IconVariant="Regular" FontSize="16" />
                        </Button>
                        <Button x:Name="ZoomOutButton"
                                Classes="Icon MapOverlay"
                                ToolTip.Tip="{x:Static loc:Strings.Tooltip_ZoomOut}">
                            <ic:FluentIcon Icon="ZoomOut" IconVariant="Regular" FontSize="16" />
                        </Button>
                        <Button x:Name="ZoomToExtentButton"
                                Classes="Icon MapOverlay"
                                ToolTip.Tip="{x:Static loc:Strings.Tooltip_ZoomToExtent}">
                            <ic:FluentIcon Icon="ZoomFit" IconVariant="Regular" FontSize="16" />
                        </Button>
                    </StackPanel>
                    <views:CompassRoseView x:Name="CompassRose"
                                           Margin="0,4,0,0"
                                           Width="{Binding Bounds.Width, ElementName=ZoomInButton}"
                                           Height="{Binding Bounds.Width, ElementName=ZoomInButton}" />
                </StackPanel>

                <!-- Partial-failure / failure banner (es3-progress).
                     Anchored to the top of the map area; dismissable via the
                     X button. Stays out of the way of the scale bar by
                     reserving the top edge with a small offset. -->
                <Border HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Margin="48,4,180,0"
                        Padding="12,8"
                        CornerRadius="4"
                        Background="{DynamicResource BackgroundColor}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        IsVisible="{Binding IsExchangeSetBannerVisible}">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding DismissExchangeSetBannerCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.Banner_Dismiss}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4"
                                Margin="8,0,0,0">
                            <ic:FluentIcon Icon="Dismiss" IconVariant="Regular" FontSize="14" />
                        </Button>
                        <TextBlock Text="{Binding ExchangeSetBannerMessage}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </DockPanel>
                </Border>

                <!-- Exchange-set progress overlay (es3-progress).
                     Centered card; non-modal — the user can still pan the
                     map underneath but cannot start a second exchange-set
                     load until this one completes or is cancelled. -->
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="320" MaxWidth="480"
                        Padding="16"
                        CornerRadius="6"
                        Background="{DynamicResource BackgroundColor}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        IsVisible="{Binding IsExchangeSetLoading}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Color="Black" Opacity="0.25" />
                    </Border.Effect>
                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Static loc:Strings.Progress_ExchangeSetTitle}"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock Text="{Binding ExchangeSetSourceLabel}"
                                   FontSize="12"
                                   Opacity="0.7"
                                   TextTrimming="CharacterEllipsis" />
                        <ProgressBar Value="{Binding ExchangeSetProgressFraction}"
                                     Minimum="0" Maximum="1"
                                     Height="4" />
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding ExchangeSetCounter}"
                                       FontSize="12"
                                       Opacity="0.7" />
                            <TextBlock Text="{Binding ExchangeSetCurrentDataset}"
                                       FontSize="12"
                                       Opacity="0.85"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <Button HorizontalAlignment="Right"
                                Command="{Binding CancelExchangeSetCommand}"
                                Content="{x:Static loc:Strings.Progress_ExchangeSetCancel}"
                                ToolTip.Tip="{x:Static loc:Strings.Progress_ExchangeSetCancel}" />
                    </StackPanel>
                </Border>
                </Grid>

                <!-- Resize grip between map and timeline panel -->
                <GridSplitter Grid.Row="1"
                              Classes="PaneSplitter"
                              Height="4"
                              ResizeDirection="Rows"
                              IsVisible="{Binding IsTimelineVisible}"
                              bh:HoverDelay.DelayMilliseconds="500"
                              Name="TimelineSplitter" />

                <!-- Global time slider for time-varying datasets (S-104, S-111, S-411) -->
                <Border Grid.Row="2"
                        x:Name="TimelinePanel"
                        Background="{DynamicResource BackgroundColor}"
                        IsVisible="{Binding IsTimelineVisible}">
                    <views:TimelineView DataContext="{Binding Timeline}" />
                </Border>
            </Grid>
            <GridSplitter Grid.Column="3"
                          Classes="PaneSplitter"
                          Width="4"
                          ResizeDirection="Columns"
                          IsVisible="{Binding IsPickPanelVisible}"
                          bh:HoverDelay.DelayMilliseconds="500"
                          Name="PickPanelSplitter" />

            <!-- Pick Report (Object Information) panel -->
            <Border Grid.Column="4"
                    Background="{DynamicResource BackgroundColor}"
                    IsVisible="{Binding IsPickPanelVisible}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static loc:Strings.Pick_PanelTitle}"
                                       FontSize="11"
                                       FontWeight="Normal"
                                       LetterSpacing="1"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding PickReport.ClearCommand}"
                                    ToolTip.Tip="{x:Static loc:Strings.Tooltip_ClosePickPanel}"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center">
                                <ic:FluentIcon Icon="Dismiss" IconVariant="Regular" FontSize="14" />
                            </Button>
                        </Grid>
                    </Border>

                    <!--
                        Sticky header: hit list + identity block + references all
                        stay pinned to the top of the panel; only the attribute
                        list scrolls. Each block carries its own DataContext so
                        bindings against PickReportViewModel work in both the
                        sticky region and the scrolling region.
                    -->
                    <StackPanel DockPanel.Dock="Top"
                                Spacing="10"
                                Margin="12,4,12,8"
                                DataContext="{Binding PickReport}">
                        <!-- Hit list (visible only when more than one feature is at this point) -->
                        <Border BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="0,0,0,1"
                                Padding="0,0,0,8"
                                IsVisible="{Binding HasMultipleHits}">
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="10"
                                           FontWeight="Normal"
                                           LetterSpacing="1"
                                           Opacity="0.7"
                                           Text="{Binding Hits.Count, StringFormat={x:Static loc:Strings.Pick_HitListHeader}}" />
                                <ListBox ItemsSource="{Binding Hits}"
                                         SelectedItem="{Binding SelectedHit, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         MaxHeight="180">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PickHit">
                                            <TextBlock FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{x:Static loc:Strings.Tooltip_SelectHit}">
                                                <Run Text="{Binding DisplayLabel}" />
                                                <Run Text=" — " FontWeight="Light" />
                                                <Run Text="{Binding FeatureRef}" FontStyle="Italic" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Header block: feature type + identity -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding FeatureType}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <TextBlock FontSize="11" Opacity="0.7">
                                <Run Text="{x:Static loc:Strings.Pick_IdLabel}" />
                                <Run Text="{Binding FeatureRef}" />
                            </TextBlock>
                            <TextBlock FontSize="11" Opacity="0.7"
                                       Text="{Binding ProductSpec, StringFormat={x:Static loc:Strings.Pick_SpecFormat}}" />
                            <TextBlock FontSize="11" Opacity="0.7"
                                       Text="{Binding DatasetFileName, StringFormat={x:Static loc:Strings.Pick_SourceFormat}}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- References list (xlink:href targets) -->
                        <Border BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="0,1,0,0"
                                Padding="0,8,0,0"
                                IsVisible="{Binding HasReferences}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:Strings.Pick_ReferencesHeader}"
                                           FontSize="10"
                                           FontWeight="Normal"
                                           LetterSpacing="1"
                                           Opacity="0.7" />
                                <ItemsControl ItemsSource="{Binding References}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="pp:FeatureReference">
                                            <Button Margin="0,1"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent"
                                                    Command="{Binding $parent[ItemsControl].((vm:PickReportViewModel)DataContext).NavigateCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="{x:Static loc:Strings.Tooltip_FollowReference}">
                                                <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding Role}" />
                                                    <Run Text=" → " FontWeight="Light" />
                                                    <Run Text="{Binding TargetRef}" FontStyle="Italic" />
                                                </TextBlock>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Scrolling region: attributes only -->
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="12,0,12,12">
                        <Border BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="0,1,0,0"
                                Padding="0,8,0,0"
                                DataContext="{Binding PickReport}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:Strings.Pick_AttributesHeading}"
                                           FontSize="10"
                                           FontWeight="Normal"
                                           LetterSpacing="1"
                                           Opacity="0.7" />
                                <TreeView ItemsSource="{Binding Attributes}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0">
                                    <TreeView.Styles>
                                        <!--
                                            Expand every attribute node by default
                                            so users see complex/sub-attribute
                                            values without an extra click.
                                        -->
                                        <Style Selector="TreeViewItem">
                                            <Setter Property="IsExpanded" Value="True" />
                                        </Style>
                                    </TreeView.Styles>
                                    <TreeView.ItemTemplate>
                                        <TreeDataTemplate x:DataType="pp:PickAttribute"
                                                          ItemsSource="{Binding Children}">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DisplayName}"
                                                           FontSize="12"
                                                           Opacity="0.7"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding Code}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DisplayText}"
                                                           FontSize="12"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="220"
                                                           ToolTip.Tip="{Binding RawValue}" />
                                            </Grid>
                                        </TreeDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                                <TextBlock Text="{x:Static loc:Strings.Pick_NoAttributes}"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           Opacity="0.6"
                                           IsVisible="{Binding !HasAttributes}" />
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</shadui:Window>
